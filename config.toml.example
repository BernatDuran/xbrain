[paths]
# Absolute path to your Obsidian vault root.
vault = "/absolute/path/to/your/obsidian/vault"
# Output folder for generated markdown, relative to the vault root.
output_subdir = "learnings/x-knowledge"
# Data directory for the JSON store, relative to the repo root.
data_dir = "data"

[x]
# Your X handle, without the @.
handle = "your_handle"

[llm]
# Text LLM provider for the "api" executor:
#   "nanogpt"   - calls NanoGPT's OpenAI-compatible chat completions API [default]
#   "anthropic" - Anthropic provider for all API-backed LLM calls (needs ANTHROPIC_API_KEY)
provider = "nanogpt"
# NanoGPT-only API base URL; ignored when provider = "anthropic".
base_url = "https://nano-gpt.com/api/v1"
# API LLM model used by text stages: enrich, vocab and topics.
model = "zai-org/glm-5.2"
# Separate API LLM model for image/vision tasks (`describe` and digest-video frames).
# With NanoGPT, default is minimax/minimax-m3 because text-only models may not process images.
vision_model = "minimax/minimax-m3"

[enrich]
# Executor that produces the LLM judgment:
#   "claude-code" - exports a worksheet a Claude Code session fills (no API cost) [default]
#   "api"         - calls [llm].provider (NanoGPT by default, needs NANOGPT_API_KEY)
#   "manual"      - exports a worksheet to fill by hand
executor = "claude-code"

[vocab]
# Number of topics the `vocab` stage induces from the corpus.
target_count = 30

[topics]
# Re-synthesize a topic's overview when it has grown by this many posts since
# the last synthesis. `xbrain topics --resynth` re-synthesizes every stale one.
resynth_threshold = 25

[output]
# Output language for LLM-generated summaries/overviews AND the wiki's
# section headers (Topics:, Content:, Summary, ...). Supported values:
#   "English" - default
#   "Spanish"
language = "English"
# How the in-body `**Topics:**` line is rendered on each item note.
# Frontmatter `tags:` are unaffected by this setting. Supported values:
#   "wikilink" - **Topics:** [[ai-coding]] · [[software-engineering]]  (default)
#   "hashtag"  - **Topics:** #ai-coding #software-engineering
topic_style = "wikilink"

[describe]
# Description-version tag persisted on every described image. Bumping
# this value invalidates existing descriptions: the next `xbrain
# describe` run re-describes stale entries automatically. Use it when
# you change the describe-image rubric or expectations.
version = "v1"

[transcribe]
# External transcriber that `xbrain digest-video` shells out to. The heavy ASR
# (Parakeet TDT 0.6b via `parakeet-mlx` on Apple Silicon; `whisper` /
# `faster-whisper` is the portable fallback) lives OUTSIDE xbrain core — the CLI
# carries no MLX/CoreML dependency and only invokes this command as a subprocess.
# May be a multi-token wrapper (split with shlex, run without a shell). xbrain
# invokes:  <command> [--model M] --output-format json --output-dir <TMPDIR> <mediapath>
# and reads the JSON transcript from the FILE parakeet-mlx writes at
# <TMPDIR>/<stem>.json ({"text", "language", "segments":[{start,end,text}]}).
# Note: --language is NOT passed (parakeet auto-detects and rejects it). A wrapper
# that emits JSON on stdout instead of a file is also supported.
#
# The bundled `scripts/xbrain-transcribe` wraps parakeet-mlx so videos with NO
# audio track (silent clips, GIFs) attach as has_speech=false instead of failing
# (parakeet writes no file for them). Point at the wrapper, or straight at
# `parakeet-mlx` if you don't need silent-video handling.
command = "parakeet-mlx"
# command = "/absolute/path/to/scripts/xbrain-transcribe"
# Optional model id passed through to the transcriber. Omit for the tool default.
# model = "parakeet-tdt-0.6b-v2"

[vision]
# Optional external vision model that `xbrain digest-video --frames` shells out
# to (#44 PR4) to describe key-frame slides. Leave it unset on a VPS/NanoGPT
# setup: xbrain will call [llm].provider + [llm].vision_model directly. Set it
# only when you want a local/custom VLM subprocess. xbrain invokes:
#   <command> [--model M] <image-path>
# and reads the frame's text description from stdout. May be a multi-token wrapper
# (split with shlex, run without a shell). `--frames` is fully opt-in: a normal
# `digest-video` run never touches ffmpeg or this command.
#
# The bundled `scripts/xbrain-vision` wrapper routes local aliases to mlx-vlm and
# every cloud call through `[llm].provider` (NanoGPT by default). Pick per run
# with `digest-video --vision-model NAME`, or set the default here:
#   local (Apple Silicon, free/offline): qwen-3b | qwen-7b | qwen-32b | local:<hf/repo>
#   cloud via NanoGPT:                    any NanoGPT vision model id, e.g. minimax/minimax-m3
#   cloud via Anthropic:                  set [llm].provider="anthropic", then opus|sonnet|haiku
# command = "/absolute/path/to/scripts/xbrain-vision"
# model = "qwen-3b"                       # omit → [llm].vision_model
