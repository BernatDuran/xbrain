[paths]
# Absolute path to your Obsidian vault root.
vault = "/absolute/path/to/your/obsidian/vault"
# Output folder for generated markdown, relative to the vault root.
output_subdir = "learnings/x-knowledge"
# Data directory for the JSON store, relative to the repo root.
data_dir = "data"

[x]
# Your X handle, without the @.
handle = "your_handle"

[llm]
# Text LLM provider for the "api" executor:
#   "nanogpt"   - calls NanoGPT's OpenAI-compatible chat completions API [default]
#   "anthropic" - Anthropic provider for all API-backed LLM calls (needs ANTHROPIC_API_KEY)
provider = "nanogpt"
# NanoGPT-only API base URL; ignored when provider = "anthropic".
base_url = "https://nano-gpt.com/api/v1"
# API LLM model used by text stages: enrich, vocab and topics.
model = "zai-org/glm-5.2"
# Separate API LLM model for image/vision tasks (`describe`).
# With NanoGPT, default is xiaomi/mimo-v2.5 because text-only models may not process images.
vision_model = "xiaomi/mimo-v2.5"

[enrich]
# Executor that produces the LLM judgment:
#   "claude-code" - exports a worksheet a Claude Code session fills (no API cost) [default]
#   "api"         - calls [llm].provider (NanoGPT by default, needs NANOGPT_API_KEY)
#   "manual"      - exports a worksheet to fill by hand
executor = "claude-code"

[vocab]
# Number of topics the `vocab` stage induces from the corpus.
target_count = 30

[topics]
# Re-synthesize a topic's overview when it has grown by this many posts since
# the last synthesis. `xbrain topics --resynth` re-synthesizes every stale one.
resynth_threshold = 25

[output]
# Output language for LLM-generated summaries/overviews AND the wiki's
# section headers (Topics:, Content:, Summary, ...). Supported values:
#   "English" - default
#   "Spanish"
language = "English"
# How the in-body `**Topics:**` line is rendered on each item note.
# Frontmatter `tags:` are unaffected by this setting. Supported values:
#   "wikilink" - **Topics:** [[ai-coding]] · [[software-engineering]]  (default)
#   "hashtag"  - **Topics:** #ai-coding #software-engineering
topic_style = "wikilink"

[describe]
# Description-version tag persisted on every described image. Bumping
# this value invalidates existing descriptions: the next `xbrain
# describe` run re-describes stale entries automatically. Use it when
# you change the describe-image rubric or expectations.
version = "v1"

# Video policy:
# `xbrain digest-video` does not download/store MP4, audio or frames. It uses
# caption/text-track URLs captured from X when available, stores the raw
# transcript as a reference artifact, and sends only an executive summary through
# enrich/topics/dashboard/Ask. Legacy `[transcribe]` / `[vision]` settings are
# intentionally omitted from the normal configuration.
