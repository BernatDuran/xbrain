# Copy to .env and fill only the secrets/options you use.

# Text LLM used by `xbrain ... --executor api`.
XBRAIN_LLM_PROVIDER=nanogpt
NANOGPT_API_KEY=
NANOGPT_MODEL=zai-org/glm-5.2
NANOGPT_VISION_MODEL=xiaomi/mimo-v2.5
NANOGPT_BASE_URL=https://nano-gpt.com/api/v1

# Optional fetch fallback for JavaScript-heavy external articles.
FIRECRAWL_API_KEY=

# Only needed when XBRAIN_LLM_PROVIDER=anthropic.
ANTHROPIC_API_KEY=
